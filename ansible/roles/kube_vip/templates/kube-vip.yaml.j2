---
apiVersion: v1
kind: Pod
metadata:
  name: kube-vip
  namespace: kube-system
spec:
  hostNetwork: true
  # kube-vip resolves "kubernetes" via DNS before the VIP is up; map it to the
  # local API server so it can acquire the leader-election lease.
  hostAliases:
    - ip: "127.0.0.1"
      hostnames:
        - "kubernetes"
        - "kubernetes.default"
        - "kubernetes.default.svc"
        - "kubernetes.default.svc.cluster.local"
  containers:
    - name: kube-vip
      image: {{ kube_vip_image }}
      imagePullPolicy: IfNotPresent
      args: [manager]
      env:
        # Point in-cluster client at the local API so kube-vip doesn't try
        # to resolve "kubernetes" DNS before the VIP is up.
        - name: KUBERNETES_SERVICE_HOST
          value: "127.0.0.1"
        - name: KUBERNETES_SERVICE_PORT
          value: "6443"
        - name: vip_arp
          value: "true"
        - name: port
          value: "6443"
        - name: vip_interface
          value: {{ kube_vip_interface }}
        - name: vip_cidr
          value: "32"
        - name: cp_enable
          value: "true"
        - name: cp_namespace
          value: kube-system
        - name: vip_ddns
          value: "false"
        - name: svc_enable
          value: "false"
        - name: vip_leaderelection
          value: "true"
        - name: vip_leaseduration
          value: "5"
        - name: vip_renewdeadline
          value: "3"
        - name: vip_retryperiod
          value: "1"
        - name: address
          value: "{{ rke2_api_vip }}"
      securityContext:
        capabilities:
          add: [NET_ADMIN, NET_RAW, SYS_TIME]
      volumeMounts:
        - mountPath: /etc/kubernetes/admin.conf
          name: kubeconfig
  volumes:
    - name: kubeconfig
      hostPath:
        path: /etc/rancher/rke2/rke2.yaml
        type: File
