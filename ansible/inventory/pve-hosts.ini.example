# Static inventory for the Proxmox hypervisor hosts themselves
# (separate from `hosts.ini`, which is generated by OpenTofu for the cluster VMs).
#
# Copy this to `pve-hosts.ini` and update for your environment:
#     cp ansible/inventory/pve-hosts.ini.example ansible/inventory/pve-hosts.ini
#
# Used by `make bootstrap-pve` and `make wipeclean` (root-side setup / teardown
# of the TerraformProv role, terraform@pve user, Snippets content type, etc.).

[proxmox_hosts]
stru-prox0 ansible_host=10.74.2.20
stru-prox1 ansible_host=10.74.2.21
stru-prox2 ansible_host=10.74.2.22

[proxmox_hosts:vars]
ansible_user=root
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_python_interpreter=/usr/bin/python3
