# Proxmox API
# Endpoint: any cluster node URL (port 8006). Self-signed certs are accepted via INSECURE=true.
PROXMOX_VE_ENDPOINT=https://10.74.2.20:8006/
PROXMOX_VE_API_TOKEN=terraform@pve!provisioner=PASTE-UUID-HERE
PROXMOX_VE_INSECURE=true

# Used by bpg/proxmox for file uploads (snippets, ISO imports)
PROXMOX_VE_SSH_USERNAME=root
# If your root account doesn't use key-only SSH, set this; otherwise use ssh-agent.
# PROXMOX_VE_SSH_PASSWORD=

# RKE2 shared cluster token. Generate with: openssl rand -hex 32
RKE2_TOKEN=replace-with-openssl-rand-hex-32

# SSH key Ansible uses to reach the VMs. Public key is also injected into cloud-init.
ANSIBLE_SSH_KEY_FILE=~/.ssh/id_ed25519
SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub

# Longhorn UI basic-auth password (htpasswd is generated at apply time)
LONGHORN_UI_USER=admin
LONGHORN_UI_PASS=changeme
