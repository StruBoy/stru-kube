# Proxmox API
# Endpoint: any cluster node URL (port 8006). Self-signed certs are accepted via INSECURE=true.
PROXMOX_VE_ENDPOINT=https://10.74.2.20:8006/
PROXMOX_VE_API_TOKEN=terraform@pve!provisioner=PASTE-UUID-HERE
PROXMOX_VE_INSECURE=true

# Used by bpg/proxmox for file uploads (snippets, ISO imports)
PROXMOX_VE_SSH_USERNAME=root
# If your root account doesn't use key-only SSH, set this; otherwise use ssh-agent.
# PROXMOX_VE_SSH_PASSWORD=

# RKE2 shared cluster token. Generate with: openssl rand -hex 32
RKE2_TOKEN=replace-with-openssl-rand-hex-32

# SSH key Ansible uses to reach the VMs. Public key is also injected into cloud-init.
ANSIBLE_SSH_KEY_FILE=~/.ssh/id_ed25519
SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub

# Longhorn UI basic-auth password (htpasswd is generated at apply time)
LONGHORN_UI_USER=admin
LONGHORN_UI_PASS=changeme

# --- ArgoCD / Sealed Secrets (GitOps) — all OPTIONAL ---
# These are bootstrap secrets for ArgoCD itself (app secrets go through Sealed
# Secrets in Git instead). Every value here is optional: blank ones make the
# matching Ansible task skip, so `make addons` runs fine with none of them set.

# ArgoCD admin UI password (bcrypt-hashed at apply time). Blank => the chart's
# random initial password is kept (kubectl -n argocd get secret
# argocd-initial-admin-secret -o jsonpath='{.data.password}' | base64 -d).
ARGOCD_ADMIN_PASS=

# App-of-apps root: your SEPARATE GitOps repo. Leave ARGOCD_ROOT_REPO_URL blank
# until that repo exists — the root Application is skipped while it's empty.
ARGOCD_ROOT_REPO_URL=
ARGOCD_ROOT_REPO_PATH=apps
ARGOCD_ROOT_REPO_REVISION=main

# ArgoCD private-repo credentials (GitHub PAT / fine-grained token). Covers ALL
# private repos under the URL prefix; public repos need nothing. Leave
# ARGOCD_GIT_TOKEN blank to skip private-repo creds entirely.
ARGOCD_GIT_URL_PREFIX=https://github.com/StruBoy/
ARGOCD_GIT_USERNAME=StruBoy
ARGOCD_GIT_TOKEN=
